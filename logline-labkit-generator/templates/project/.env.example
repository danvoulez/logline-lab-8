# No provider is required for local CLI use.
LOGLINE_LAB_PROFILE=local-offline

# Supabase profile. Prefer DATABASE_URL for the canonical Lab Kit spine. REST
# keys are supported only when a project exposes compatible RPC wrappers. Never
# commit real keys.
DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Doppler Santo Andre uses SUPABASE_SECRET_KEY; the CLI accepts it as the same
# server-side secret key when SUPABASE_SERVICE_ROLE_KEY is absent.
SUPABASE_SECRET_KEY=
